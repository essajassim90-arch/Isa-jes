{
  "name": "nama-protocol",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@nama/web",
    "build": "npm run build --workspace=@nama/web",
    "lint": "npm run lint --workspace=@nama/web",
    "preview": "npm run preview --workspace=@nama/web",
    "typecheck": "npm run build --workspace=@nama/web -- --noEmit 2>/dev/null || tsc -p apps/web/tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@reown/appkit": "^1.8.22",
    "@reown/appkit-adapter-wagmi": "^1.8.22",
    "@tanstack/react-query": "^5.101.2",
    "@vechain/dapp-kit-react": "^2.1.0-rc.1",
    "@vechain/sdk-core": "^2.0.7",
    "@vechain/vechain-kit": "^2.12.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "^2.55.0",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "buffer": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
