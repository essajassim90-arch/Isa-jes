# WalletConnect project ID — get one at https://cloud.walletconnect.com
# Optional for CI/demo builds. Required for live WalletConnect/EVM wallet connectivity.
VITE_WC_PROJECT_ID=

# Privy social login — get keys at https://privy.io
VITE_PRIVY_APP_ID=
VITE_PRIVY_CLIENT_ID=

# VeChain network — "testnet" for staging, "mainnet" for production
VITE_VECHAIN_NETWORK=testnet

# Backend API base URL — e.g. http://localhost:3001 for local dev, https://<host> for staging
VITE_API_URL=

# VeChain testnet contract addresses — fill in after deploying packages/contracts to testnet
VITE_CONTRACT_DPP=
VITE_CONTRACT_MARKETPLACE=

# API runtime secret — required for apps/api in every non-development deployment
JWT_SECRET=

# ── Deployment (packages/contracts) ───────────────────────────────────────────
# Deployer account private key (hex, no 0x prefix required by Hardhat)
# Used by: npx hardhat ignition deploy ... --network vechain_testnet
DEPLOYER_PRIVATE_KEY=

# Optional — override the default VeChainThor Testnet RPC endpoint
VECHAIN_TESTNET_RPC_URL=https://testnet.vechain.org

# ── Indexer runtime (apps/indexer) ────────────────────────────────────────────
# Deployed contract addresses for the live indexer runtime
DPP_CONTRACT_ADDRESS=
MARKETPLACE_CONTRACT_ADDRESS=

# Optional runtime overrides for co-located API + indexer deployments
THOR_URL=https://testnet.vechain.org
CHAIN_ID=39
DB_PATH=/var/lib/nama/projections/projections.db
CHECKPOINT_PATH=/var/lib/nama/projections/checkpoints.json

# ── API runtime (apps/api) ────────────────────────────────────────────────────
# Read-only path to the SQLite projection database written by the indexer
PROJECTION_DB_PATH=/var/lib/nama/projections/projections.db
